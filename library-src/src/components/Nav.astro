---
export interface Props {
  links?: { href: string; label: string }[];
}

const BASE = import.meta.env.BASE_URL.replace(/\/$/, '');

const defaultLinks = [
  { href: '#reading', label: 'Currently Reading' },
  { href: '#top10',   label: 'Top 10' },
  { href: '#years',   label: 'Year by Year' },
  { href: `${BASE}/all`, label: 'All Books' },
];

const { links = defaultLinks } = Astro.props;
---

<nav class="site-nav">
  <div style="max-width:1400px;margin:0 auto;padding:0 2rem;display:flex;align-items:center;justify-content:space-between;height:100%;">
    <div style="display:flex;align-items:center;gap:0.75rem;">
      <a href="/" style="font-family:'Inter',sans-serif;font-size:0.9rem;font-weight:700;letter-spacing:-0.01em;color:var(--c-text-2);text-decoration:none;transition:color 0.15s;"
        onmouseover="this.style.color='var(--c-text)'"
        onmouseout="this.style.color='var(--c-text-2)'">
        Drew Klauser
      </a>
      <span style="color:var(--c-text-3);font-weight:300;font-size:1.1rem;" aria-hidden="true">/</span>
      <a href={`${BASE}/`} style="font-family:'Inter',sans-serif;font-size:0.9rem;font-weight:600;color:var(--c-purple);text-decoration:none;">Library</a>
    </div>

    <div style="display:flex;gap:2rem;align-items:center;">
      {links.map(({ href, label }) => (
        <a
          href={href}
          style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;color:var(--c-text-2);text-decoration:none;transition:color 0.15s;"
          onmouseover="this.style.color='var(--c-purple)'"
          onmouseout="this.style.color='var(--c-text-2)'"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</nav>
